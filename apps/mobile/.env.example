# Variables de entorno para la PWA mobile.
#
# Configurarlas en Vercel (Settings → Environment Variables) NO en el repo.
# Este .env.example documenta qué keys necesitás.

# Connection string al pooler de Supabase (port 6543, IPv4-compatible).
# Mismo valor que el .env del repo raíz.
SUPABASE_DB_URL_POOLED=postgresql://postgres.<REF>:<PASSWORD>@aws-X-<REGION>.pooler.supabase.com:6543/postgres

# Secreto para firmar JWTs de sesión. Mínimo 32 chars random.
# Generalo con: `openssl rand -hex 32`
# Si lo rotás, todas las sesiones se invalidan (los usuarios re-loggean).
MOBILE_AUTH_SECRET=poner-aqui-32-chars-aleatorios-minimo

# Opcional: URL pública canónica (usada en og:tags + redirects).
# NEXT_PUBLIC_SITE_URL=https://mobile.santateresita.com.ar
