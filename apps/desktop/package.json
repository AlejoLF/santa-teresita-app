{
  "name": "@sta/desktop",
  "version": "1.25.0",
  "private": true,
  "description": "Santa Teresita Pastas — desktop app (full local stack)",
  "main": "main.js",
  "author": {
    "name": "Santa Teresita Pastas"
  },
  "scripts": {
    "start": "electron .",
    "build:resources": "node scripts/build-resources.mjs",
    "build": "node scripts/build-resources.mjs && electron-builder --win",
    "release": "node scripts/build-resources.mjs && electron-builder --win --publish always",
    "release:draft": "node scripts/build-resources.mjs && electron-builder --win --publish onTagOrDraft"
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "embedded-postgres": "^18.3.0-beta.17",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "@electron/asar": "^4.2.0",
    "commander": "^14.0.3",
    "electron": "^33.2.0",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.24.2"
  }
}
