# ════════════════════════════════════════════════════════════════════
#  Santa Teresita — SERVIDOR LOCAL (mini PC). Copiar a .env y completar.
#  Ver docs/SERVIDOR-LOCAL.md
# ════════════════════════════════════════════════════════════════════

NODE_ENV=production

# Rol del proceso. En el mini PC SIEMPRE 'server' (arranca el replicator).
STA_ROLE=server

# Produce outbox_events en la misma tx que el audit (necesario para
# replicar local → Supabase). En el server SIEMPRE true.
STA_OUTBOX_REPLICATION=true

# Postgres LOCAL del mini PC = FUENTE DE VERDAD. Cambiar la password.
DATABASE_URL=postgresql://teresita:CAMBIAR_PASSWORD@127.0.0.1:5432/teresita?schema=public

# Destino del mirror/backup: pooler de Supabase (aws-1, NO aws-0 legacy).
# Si se deja vacío, el replicator NO arranca (el server igual funciona,
# pero sin backup a la nube).
REPLICATE_TO_URL=postgresql://postgres.SUPABASE_REF:CAMBIAR_PASSWORD@aws-1-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1

# API: 0.0.0.0 para que las cajas de la LAN puedan conectarse.
API_HOST=0.0.0.0
API_PORT=3001

# Orígenes CORS permitidos: el web de Vercel + cualquier preview.
API_CORS_ORIGINS=https://sta-desktop.vercel.app

# CRÍTICO: estos dos DEBEN ser idénticos en TODO el sistema (server, cajas,
# API de Vercel). El hash-chain del audit y las sesiones se rompen si
# difieren. Copiar los MISMOS valores que ya usa el resto del sistema.
AUTH_SECRET=CAMBIAR_min_32_chars_iguales_en_todo_el_sistema
AUDIT_HASH_SALT=CAMBIAR_min_16_chars_iguales_en_todo

AUTH_SESSION_TTL_HOURS_VENDEDOR=12
AUTH_SESSION_TTL_HOURS_ADMIN=2

# Timezone — NO cambiar. Las fechas de sesión dependen de esto
# (ver gotcha en CLAUDE.md). Además configurar NTP en el mini PC.
TZ=America/Argentina/Buenos_Aires
