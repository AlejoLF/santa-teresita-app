# ════════════════════════════════════════════════════════════════════
#   SANTA TERESITA PASTAS — variables de entorno
#   Copiar a .env (gitignored). NUNCA commitear .env real.
# ════════════════════════════════════════════════════════════════════

# ── App ────────────────────────────────────────────────────────────
NODE_ENV=development
APP_NAME="Santa Teresita Pastas"
APP_TIMEZONE=America/Argentina/Buenos_Aires
LOG_LEVEL=debug

# ── API ────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=3001
API_PUBLIC_URL=http://localhost:3001
API_CORS_ORIGINS=http://localhost:3000

# ── Web ────────────────────────────────────────────────────────────
WEB_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:3001
# Supabase Realtime — opcional. Si no se setean, la app funciona sin
# notificaciones cross-PC pero el LWW sigue aplicando en el server.
# Encontrá los valores en Supabase → Settings → API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── Local Agent ────────────────────────────────────────────────────
AGENT_PORT=3002
AGENT_PRINTER_KITCHEN_HOST=192.168.1.50
AGENT_PRINTER_KITCHEN_PORT=9100
AGENT_PRINTER_COUNTER_HOST=192.168.1.51
AGENT_PRINTER_COUNTER_PORT=9100
AGENT_PRINTER_DELIVERY_HOST=192.168.1.52
AGENT_PRINTER_DELIVERY_PORT=9100

# ── PostgreSQL ─────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=teresita
POSTGRES_PASSWORD=teresita_dev_pwd
POSTGRES_DB=teresita
DATABASE_URL=postgresql://teresita:teresita_dev_pwd@localhost:5432/teresita?schema=public
DATABASE_URL_SHADOW=postgresql://teresita:teresita_dev_pwd@localhost:5432/teresita_shadow?schema=public

# ── Redis / BullMQ ─────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379

# ── Auth ───────────────────────────────────────────────────────────
AUTH_SECRET=replace_me_with_64_random_bytes_hex
AUTH_SESSION_TTL_HOURS_VENDEDOR=12
AUTH_SESSION_TTL_HOURS_ADMIN=2
AUTH_PIN_LOCKOUT_THRESHOLD=5
AUTH_PIN_LOCKOUT_MINUTES=15
AUTH_BCRYPT_ROUNDS=12

# ── Audit / Hash chain ─────────────────────────────────────────────
AUDIT_HASH_SALT=replace_me_with_random_salt
AUDIT_OFFSITE_BACKUP_S3_BUCKET=
AUDIT_OFFSITE_BACKUP_S3_REGION=
AUDIT_OFFSITE_BACKUP_S3_KEY=
AUDIT_OFFSITE_BACKUP_S3_SECRET=

# ── Sync Excel — local (v1) ────────────────────────────────────────
# Path al directorio donde están los .xlsx. Por defecto: root del repo.
EXCEL_LOCAL_DIR=
# Path a tools/. Por defecto: <repo>/tools.
TOOLS_DIR=
# Comando python (usar python3 en linux/mac, python en windows).
PYTHON_CMD=python

# ── Google Drive (v2 — sync remoto, todavía no implementado) ───────
GOOGLE_DRIVE_SERVICE_ACCOUNT_PATH=./credentials.json
GOOGLE_DRIVE_LISTA_PRECIOS_FILE_ID=
GOOGLE_DRIVE_PROVEEDORES_FILE_ID=
GOOGLE_DRIVE_VENTAS_FILE_ID=
GOOGLE_DRIVE_CASHFLOW_FILE_ID=
GOOGLE_DRIVE_POLL_MINUTES=10

# ── Plataformas de delivery ────────────────────────────────────────
RAPPI_CLIENT_ID=
RAPPI_CLIENT_SECRET=
RAPPI_WEBHOOK_SECRET=
PEDIDOSYA_CLIENT_ID=
PEDIDOSYA_CLIENT_SECRET=
PEDIDOSYA_WEBHOOK_SECRET=
MELI_APP_ID=
MELI_CLIENT_SECRET=
MELI_REDIRECT_URI=
DELIVERATE_API_KEY=

# ── MercadoPago ────────────────────────────────────────────────────
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_PUBLIC_KEY=
MERCADOPAGO_WEBHOOK_SECRET=

# ── Belvo (saldos bancarios) ───────────────────────────────────────
BELVO_SECRET_ID=
BELVO_SECRET_PASSWORD=
BELVO_ENV=sandbox

# ── Email (envío de cierres de caja al admin) ──────────────────────
# Si no se setea SMTP_HOST, el sistema cae a Ethereal (https://ethereal.email)
# que genera una URL de preview en lugar de mandar mail real. Útil para dev.
#
# Para Gmail (recomendado):
#   1. Activar verificación en 2 pasos en la cuenta google
#   2. Crear app password en https://myaccount.google.com/apppasswords
#   3. Setear SMTP_USER + SMTP_PASS y dejar SMTP_HOST=smtp.gmail.com
#
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=alejolafalce@gmail.com
# SMTP_PASS=znei pqyq kpay bpyl
# SMTP_FROM="Santa Teresita Pastas <tu-cuenta@gmail.com>"
# Lista de destinatarios por defecto (separados por coma).
# ADMIN_EMAIL_RECIPIENTS=alejolafalce@gmail.com,encargada@santateresita.com.ar

# ── WhatsApp Cloud API (fase 2) ────────────────────────────────────
META_WSP_PHONE_NUMBER_ID=
META_WSP_BUSINESS_ACCOUNT_ID=
META_WSP_ACCESS_TOKEN=
META_WSP_VERIFY_TOKEN=
META_WSP_APP_SECRET=

# ── N8N (Telegram facturas) ────────────────────────────────────────
N8N_WEBHOOK_URL=
N8N_WEBHOOK_SECRET=

# ── Anthropic / OpenAI (OCR de facturas, fallback) ─────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
