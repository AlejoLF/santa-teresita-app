// ════════════════════════════════════════════════════════════════════════
//   SANTA TERESITA PASTAS — Schema Prisma v0.1
//   Cubre secciones 2-11 del SPEC.
//   Convenciones:
//     - Nombres de modelos: PascalCase singular (Producto, Venta).
//     - Nombres de tablas: snake_case plural (productos, ventas).
//     - Decimales monetarios: Decimal(18, 2) — pesos hasta 9.999.999.999.999.999,99.
//     - Cantidades fraccionales: Decimal(12, 3) — gramos, kg, etc.
//     - Porcentajes: Decimal(7, 4) — hasta 999,9999%.
//     - Snapshots de precio en items: para que cambios futuros no afecten histórico.
//     - Soft-delete con `activo` bool en catálogos; `estado` enum en transaccionales.
//     - Timestamps: snake_case con sufijo _at (`creado_at`, `editado_at`).
// ════════════════════════════════════════════════════════════════════════

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions", "fullTextSearch"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [uuidOssp(map: "uuid-ossp"), pgcrypto, pg_trgm, unaccent, btree_gin]
}

// ════════════════════════════════════════════════════════════════════════
//   ENUMS
// ════════════════════════════════════════════════════════════════════════

enum RolUsuario {
  VENDEDOR
  ADMIN
}

enum FormaVenta {
  UNIDAD
  GRAMO
  PLANCHA
  PORCION
}

enum UnidadPrecio {
  POR_UNIDAD
  POR_GRAMO
  POR_KILO
  POR_PORCION
  POR_PLANCHA
  POR_DOCENA
}

enum TipoSeleccion {
  UNICA
  MULTIPLE
}

enum CanalListaPrecios {
  LOCAL_MOSTRADOR
  LOCAL_WEB
  WHATSAPP
  TELEFONO
  RAPPI
  PEDIDOS_YA
  MERCADO_LIBRE
  DELIVERATE
  MAYORISTA
}

enum TipoComponenteCombo {
  PRODUCTO_FIJO
  OPCION_ENTRE_VARIOS
}

enum TipoCuenta {
  EFECTIVO
  BANCO
  WALLET
}

enum MetodoActualizacionCuenta {
  MANUAL
  API_MP
  BELVO
  IMPORT_EXTRACTO
}

enum TipoCuentaACobrar {
  TARJETA_DEBITO
  TARJETA_CREDITO
  TARJETA_CUOTAS
  PLATAFORMA_DELIVERY
  EMPRESA_DELIVERY
}

enum EstadoLiquidacion {
  PENDIENTE
  LIQUIDADA
  ANULADA
}

enum TipoMovimiento {
  INGRESO
  EGRESO
  TRANSFERENCIA_INTERNA
  LIQUIDACION
  AJUSTE
}

enum EstadoMovimiento {
  PENDIENTE
  CONFIRMADO
  ANULADO
}

enum TipoCategoriaMovimiento {
  INGRESO
  EGRESO
  TRANSFERENCIA
  AMBOS
}

enum MetodoPago {
  EFECTIVO
  DEBITO
  CREDITO_1_PAGO
  CREDITO_CUOTAS
  TRANSFERENCIA
  DEPOSITO
  MERCADOPAGO_QR
  CHEQUE
  TARJETA_NARANJA
  OTRO
}

enum EstadoPago {
  PENDIENTE
  CONFIRMADO
  ANULADO
}

enum TurnoCaja {
  MANANA
  TARDE
}

enum EstadoSesionCaja {
  ABIERTA
  CERRADA
  APROBADA
}

enum CanalVenta {
  MOSTRADOR
  TELEFONO
  WHATSAPP
  WEB
  RAPPI
  PEDIDOS_YA
  MERCADO_LIBRE
  DELIVERATE
}

enum ModalidadVenta {
