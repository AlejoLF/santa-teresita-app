  DELIVERY_PROPIO
  DELIVERY_PLATAFORMA
  DELIVERY_DELIVERATE
}

enum EstadoVenta {
  PROCESADA
  FINALIZADA
  ANULADA
}

enum TipoCliente {
  CASUAL
  REGISTRADO
  CORPORATIVO
  PLATAFORMA
}

enum EstadoEntregaDelivery {
  PENDIENTE
  EN_RUTA
  ENTREGADO
  NO_ENTREGADO
  DEVUELTO
}

enum CondicionIva {
  RESPONSABLE_INSCRIPTO
  MONOTRIBUTO
  EXENTO
  CONSUMIDOR_FINAL
}

enum CategoriaInsumo {
  VERDULERIA
  LACTEOS
  CARNES
  POLLO
  HUEVOS
  HARINAS
  CONDIMENTOS
  ENVASES
  LIMPIEZA
  BEBIDAS
  SIN_TACC
  POSTRES
  OTROS
