# Dependencies
node_modules/
.pnpm-store/

# Build output
dist/
build/
.next/
out/
*.tsbuildinfo
# Excepción: scripts NSIS source-controlled de electron-builder (se necesita
# en el repo para que CI pueda compilar el installer).
!apps/desktop/build/
apps/desktop/build/*
!apps/desktop/build/installer.nsh

# Env
.env
.env.local
.env.*.local
credentials.json
token.json
*.pem
*.key

# Prisma
**/prisma/migrations/dev.db*
**/.prisma/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
logs/

# Editor
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# Tmp / disposable
.tmp/
tmp/
*.tmp

# Test / coverage
coverage/
.nyc_output/

# Docker volumes (local dev)
infra/docker/data/

# Excel generados
*.lock
~$*.xlsx

# Excel del cliente — contienen datos reales del negocio (precios, proveedores,
# ventas, cashflow). NO subir al repo. Si hace falta algún sample, dejar uno
# anonimizado en `docs/samples/` con datos ficticios.
/*.xlsx
/*.xls

# Vercel local — contiene OIDC token y project linkage
.vercel/

# Desktop build artifacts (resources/ se regenera, out/ ya cubierto arriba,
# dist/ es el output de electron-builder)
apps/desktop/resources/
apps/desktop/dist/
# VC++ Redist se descarga en cada build (script ensure:vcredist) — 25MB de
# binario que no aporta a git history, mejor regenerarlo on-demand.
apps/desktop/build/vc_redist.x64.exe

# Postgres data dir (si alguien arranca el agente local en este directorio)
pgdata/
data/pgdata/

# Claude Code config local (project-level)
.claude/
.mcp.json.local

# Trabajo temporal (auditoría / planificación) — se borra al terminar
ROADMAP-AUDIT-FIXES.md
NOTES-*.md
